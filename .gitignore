# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
jspm_packages/

# ── Environment files (NEVER commit secrets) ──────────────────────────────────
.env
.env.local
.env.development
.env.test
.env.production
*.env

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Coverage & test artifacts ─────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Temp upload directory ─────────────────────────────────────────────────────
backend/public/temp/*
!backend/public/temp/.gitkeep

# ── Vite/Vitest cache ─────────────────────────────────────────────────────────
.vite/
.vitest/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
*.tsbuildinfo
.cache/
.parcel-cache/
